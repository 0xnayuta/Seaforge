# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Explicit text files (safety net for binary-detection edge cases)
*.ts       text eol=lf
*.tsx      text eol=lf
*.mjs      text eol=lf
*.js       text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.env       text eol=lf
*.gitignore text eol=lf

# Explicit binaries — never touch
*.ico      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.svg      binary
*.woff     binary
*.woff2    binary
*.eot      binary
*.ttf      binary
